# This file controls what gets uploaded to Cloud Build (source tarball).
# Only app/ and requirements.txt are needed to build the Docker image.
.gcloudignore

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
wheels/

# Virtual environments (huge — never needed)
venv/
.venv/
env/
genv/
enterprise_env/
tenvv/

# Secrets
.env
commands.md

# Git & IDE
.git/
.gitignore
.dockerignore
.vscode/
.idea/

# Observability local state
.logfire/

# Claude Code memory
.claude/

# Data — lives in GCS, not needed for the build
DATA/

# Eval suite — local only
evals/

# Streamlit UI — local only
ui/

# Notebooks & docs
notebooks/
DOCS/
README.md

# OS
.DS_Store
Thumbs.db
*.log
